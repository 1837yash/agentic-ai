# ---------------------------------------------------------------------------
# Base agent  (new google.genai agentic loop)
# ---------------------------------------------------------------------------

class BaseAgent:
    def __init__(self, name: str, system_prompt: str, tool_declarations: list):
        self.name = name
        self.system_prompt = system_prompt
        self.tools = [types.Tool(function_declarations=tool_declarations)]
        self.config = types.GenerateContentConfig(
            system_instruction=system_prompt,
            tools=self.tools,
        )

    def run(self, user_message: str) -> tuple:
        """
        Agentic loop using the new SDK.
        Returns (final_text, last_function_args).
        """
        print(f"\n{'-'*60}")
        print(f"Agent : {self.name}")
        print(f"Input : {user_message[:120]}")
        print(f"{'-'*60}")

        contents = [types.Content(role="user", parts=[types.Part(text=user_message)])]
        last_fn_args = {}

        while True:
            response = client.models.generate_content(
                model=MODEL,
                contents=contents,
                config=self.config,
            )

            # Append model response to history
            contents.append(
                types.Content(role="model", parts=response.candidates[0].content.parts)
            )

            # Collect any function calls
            fn_calls = [
                p.function_call
                for p in response.candidates[0].content.parts
                if p.function_call is not None
            ]

            if not fn_calls:
                # No more function calls — return final text
                text = response.text or ""
                if text:
                    print(f"  [{self.name}]: {text[:200]}")
                return text, last_fn_args

            # Execute each function call and build responses
            fn_response_parts = []
            for fn_call in fn_calls:
                fn_name = fn_call.name
                fn_args = dict(fn_call.args)
                last_fn_args = fn_args

                print(f"  -> Tool: {fn_name}  args: {json.dumps(fn_args)[:120]}")
                result = dispatch_tool(fn_name, fn_args)
                print(f"  <- Result: {json.dumps(result)[:200]}")

                fn_response_parts.append(
                    types.Part(
                        function_response=types.FunctionResponse(
                            name=fn_name,
                            response={"result": result},
                        )
                    )
                )

            # Feed all function responses back
            contents.append(types.Content(role="user", parts=fn_response_parts))


