def mock_search_flights(origin, destination, date, num_passengers, cabin_class):
    multiplier = {"economy": 1.0, "business": 3.2, "first": 5.5}.get(cabin_class, 1.0)
    results = []
    for f in MOCK_FLIGHTS_DB:
        if (f["origin"].upper() == origin.upper() and
                f["destination"].upper() == destination.upper() and
                f["seats_available"] >= int(num_passengers)):
            flight = f.copy()
            flight["price_usd"] = round(f["price_usd"] * multiplier * int(num_passengers), 2)
            flight["date"] = date
            results.append(flight)
    return results


def mock_create_booking(flight_id, date, passengers, cabin_class):
    pnr = "".join(random.choices("ABCDEFGHJKLMNPQRSTUVWXYZ23456789", k=6))
    if isinstance(passengers, str):
        passengers = json.loads(passengers)
    return {
        "pnr": pnr,
        "flight_id": flight_id,
        "date": date,
        "cabin_class": cabin_class,
        "passengers": passengers,
        "status": "confirmed",
        "booked_at": datetime.now(timezone.utc).isoformat(),
    }


def mock_process_payment(pnr, amount_usd, card_last4="4242"):
    charge_id = "ch_" + uuid.uuid4().hex[:16]
    return {
        "charge_id": charge_id,
        "pnr": pnr,
        "amount_usd": amount_usd,
        "card_last4": card_last4,
        "status": "succeeded",
        "charged_at": datetime.now(timezone.utc).isoformat(),
    }


def mock_send_notification(pnr, email, phone, booking_details):
    if isinstance(booking_details, str):
        booking_details = json.loads(booking_details)
    print(f"\n  [EMAIL] -> {email}")
    print(f"  Subject: Booking Confirmed - PNR {pnr}")
    print(f"  Flight {booking_details['flight_id']} on {booking_details['date']}")
    print(f"  Passengers: {len(booking_details['passengers'])}")
    print(f"\n  [SMS] -> {phone}: Flight {booking_details['flight_id']} confirmed. PNR: {pnr}")
    return {"email_sent": True, "sms_sent": True, "pnr": pnr}


# ---------------------------------------------------------------------------
# Tool dispatcher  (maps function name -> mock implementation)
# ---------------------------------------------------------------------------

def dispatch_tool(fn_name: str, fn_args: dict) -> dict:
    if fn_name == "parse_travel_request":
        return {"status": "parsed", **fn_args}
    elif fn_name == "search_flights":
        flights = mock_search_flights(**fn_args)
        return {"flights": flights, "count": len(flights)}
    elif fn_name == "create_booking":
        return mock_create_booking(**fn_args)
    elif fn_name == "process_payment":
        return mock_process_payment(**fn_args)
    elif fn_name == "send_notification":
        return mock_send_notification(**fn_args)
    return {"error": f"Unknown function: {fn_name}"}


